# ═══════════════════════════════════════════════════════════════
# NEXUS AI — Frontend Environment
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# You only need ONE of the options below.

# ── OPTION A: Your trained Phi-3 / Llama model (BEST) ──────────
# After training on Colab and uploading to Hugging Face:
VITE_HF_API_KEY=hf_your_free_token_here
VITE_HF_MODEL_ID=your-username/nexus-teacher

# ── OPTION B: Groq free tier (easiest to start) ────────────────
# Get free key at console.groq.com/keys — no credit card needed
VITE_GROQ_API_KEY=gsk_your_groq_key_here

# ── OPTION C: Local model via Ollama / LM Studio ───────────────
# Run: ollama pull llama3.2:3b  then start ollama
# VITE_LOCAL_URL=http://localhost:11434

# ── OPTION D: Point to your NEXUS backend ──────────────────────
# Only needed if you want to use the backend proxy
# VITE_BACKEND_URL=https://your-backend.up.railway.app
