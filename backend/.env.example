# ═══════════════════════════════════════════════════════════════
# NEXUS AI — Backend Environment
# ═══════════════════════════════════════════════════════════════

PORT=4000
NODE_ENV=production
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# AI_PROVIDER=auto  tries all in priority order (recommended)
# AI_PROVIDER=groq  forces a specific provider
AI_PROVIDER=auto

# ── PRIORITY 1: Your trained model on Hugging Face ─────────────
# Train with: python3 ml/training/train.py guide
# Upload to: huggingface.co/new-model
# Get token: huggingface.co/settings/tokens (free)
HF_API_KEY=hf_your_free_token_here
HF_MODEL_ID=your-username/nexus-teacher

# ── PRIORITY 2: Groq (free, 14K tokens/min) ────────────────────
# Get key: console.groq.com/keys (no credit card)
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Other free/cheap options:
# GROQ_MODEL=llama-3.1-8b-instant        (faster, slightly lower quality)
# GROQ_MODEL=mixtral-8x7b-32768          (good for longer responses)
# GROQ_MODEL=gemma2-9b-it                (Google's model, very fast)

# ── PRIORITY 3: Together AI ($5 free credit) ───────────────────
# TOGETHER_API_KEY=your_together_key

# ── PRIORITY 4: OpenAI (gpt-4o-mini very cheap) ───────────────
# OPENAI_API_KEY=sk-your_openai_key
# OPENAI_MODEL=gpt-4o-mini

# ── Rate Limiting ──────────────────────────────────────────────
AI_RATE_LIMIT=60
